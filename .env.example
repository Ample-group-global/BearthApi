# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string (Railway or local)
DATABASE_URL=postgresql://user:password@host:5432/Bearth

# ── Auth ──────────────────────────────────────────────────────────────────────

# Wallet address allowed to manage the whitelist (lowercase)
ADMIN_ADDRESS=0x48ba45309d7a4ebc7d71e32ac702abae8e9fce48

# HMAC secret for whitelist admin session tokens
ADMIN_SECRET=replace-with-a-64-char-random-hex-string

# HMAC secret for presale admin session tokens (must match BearthAdmin AUTH_SECRET)
AUTH_SECRET=change-me-to-a-long-random-string

# JWT secret for password-reset tokens
RESET_SECRET=change-me-to-another-long-random-string

# ── Server ────────────────────────────────────────────────────────────────────

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:3000,https://your-admin.vercel.app

# Server port (Railway injects $PORT automatically)
PORT=8000

# Admin panel base URL (used in reset-password email links)
ADMIN_URL=http://localhost:3000

# ── Email ─────────────────────────────────────────────────────────────────────

GMAIL_SENDER_EMAIL=official@amplegroupglobal.com
GMAIL_SENDER_NAME=Ample Group Global
# Use one of the two auth approaches below (not both):
# Option A — Gmail App Password (simpler, for nodemailer SMTP)
GMAIL_APP_PASSWORD=your-16-char-gmail-app-password
# Option B — Gmail OAuth2 (same credentials as amgweb3Services GmailApiSettings)
GMAIL_CLIENT_ID=your-google-oauth2-client-id
GMAIL_CLIENT_SECRET=your-google-oauth2-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-oauth2-refresh-token

# ── External APIs ─────────────────────────────────────────────────────────────

OPENSEA_API_KEY=your-opensea-api-key

# ── Blockchain ────────────────────────────────────────────────────────────────

# Ethereum / Base RPC endpoint (Infura, Alchemy, or llamarpc)
ETH_RPC_URL=https://mainnet.infura.io/v3/your-infura-project-id

# Operations wallet private key — holds DEFAULT_ADMIN_ROLE on all contracts
# Must be the fixed wallet for mainnet (see parent CLAUDE.md: mainnet uses FIXED_PRIVATE_KEY)
FIXED_PRIVATE_KEY=0xabc...your-private-key

# ── Contract Addresses ────────────────────────────────────────────────────────
# All proxy (UUPS) addresses unless noted. Set after each deployment.

# BearthGenesisNFT proxy — main ERC721A NFT contract
CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# BearthStaking proxy — NFT staking + Bearth Points
STAKING_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# RewardToken proxy — BRT ERC-20 reward token (minted by BearthStaking)
REWARD_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000

# BearthAuction proxy — English auction contract
AUCTION_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# BearthScheduler proxy — automated phase/reveal scheduler
SCHEDULER_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# BearthUpgrade — burn-3-to-mint-1 upgrade contract (not upgradeable)
UPGRADE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# BearthUpgradeNFT — ERC721 issued for burn-to-mint upgrades (not upgradeable)
UPGRADE_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# BearthAirdrop — batch ETH/ERC20/ERC721 airdrop contract (not upgradeable)
AIRDROP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
